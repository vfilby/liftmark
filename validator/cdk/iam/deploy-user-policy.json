        "arn:aws:iam::341556346945:role/cdk-hnb659fds-image-publishing-role-341556346945-us-west-2",
        "arn:aws:iam::341556346945:role/cdk-hnb659fds-lookup-role-341556346945-us-west-2"
      ],
      "Condition": {
        "Bool": { "aws:MultiFactorAuthPresent": "true" }
      }
