---
export interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const fullTitle = title === 'LMWF' ? 'LMWF — LiftMark Workout Format' : `${title} — LMWF`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%231a1a1a'/%3E%3Ctext x='50%25' y='50%25' text-anchor='middle' dominant-baseline='central' font-family='ui-monospace,monospace' font-weight='700' font-size='24' fill='%23fdfdfc'%3ELM%3C/text%3E%3C/svg%3E" />
    <link rel="alternate" type="text/markdown" href="/spec.md" title="LMWF spec (markdown)" />
    <script is:inline>
      // Pre-paint: apply stored color-scheme before first render to avoid FOUC.
      (function () {
        try {
          var stored = localStorage.getItem('color-scheme');
          if (stored === 'light' || stored === 'dark') {
            document.documentElement.setAttribute('data-color-scheme', stored);
            document.documentElement.style.colorScheme = stored;
          }
        } catch (_) { /* storage unavailable */ }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="wordmark">LMWF</a>
        <nav aria-label="Primary">
          <a href="/spec">Spec</a>
          <a href="https://github.com/vfilby/liftmark" rel="external noopener">GitHub</a>
          <button
            type="button"
            class="color-toggle"
            id="color-toggle"
            aria-label="Toggle color scheme"
            title="Auto (system)"
          >◑</button>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p>
          <a href="https://github.com/vfilby/liftmark" rel="external noopener">Repository</a>
          <span aria-hidden="true"> · </span>
          <a href="/spec">Spec</a>
          <span aria-hidden="true"> · </span>
          <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="external noopener license">Spec: CC BY-SA 4.0</a>
        </p>
        <p class="muted">
          The LiftMark Workout Format is an open specification. The LiftMark iOS app uses it, but it is not tied to any app.
        </p>
      </div>
    </footer>

    <style is:global>
      :root {
        color-scheme: light dark;
        --color-bg: #fdfdfc;
        --color-bg-subtle: #f5f4f2;
        --color-fg: #1a1a1a;
        --color-muted: #5a5a57;
        --color-border: #e4e3df;
        --color-accent: #c2410c;
        --color-accent-hover: #9a330a;
        --color-accent-fg: #ffffff;
        --color-ok-bg: #ecfdf5;
        --color-ok-fg: #065f46;
        --color-ok-border: #6ee7b7;
        --color-err-bg: #fef2f2;
        --color-err-fg: #991b1b;
        --color-err-border: #fca5a5;
        --font-sans: ui-sans-serif, -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto, "Helvetica Neue", Arial, sans-serif;
        --font-mono: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
        --max-width: 44rem;
      }

      @media (prefers-color-scheme: dark) {
        :root:not([data-color-scheme="light"]) {
          --color-bg: #0f0f0e;
          --color-bg-subtle: #1c1c1a;
          --color-fg: #e8e7e3;
          --color-muted: #a5a39e;
          --color-border: #2e2d29;
          --color-accent: #f97316;
          --color-accent-hover: #fb923c;
          --color-accent-fg: #0f0f0e;
          --color-ok-bg: #052e1f;
          --color-ok-fg: #a7f3d0;
          --color-ok-border: #065f46;
          --color-err-bg: #2c0a0a;
          --color-err-fg: #fca5a5;
          --color-err-border: #7f1d1d;
        }
      }

      :root[data-color-scheme="dark"] {
        --color-bg: #0f0f0e;
        --color-bg-subtle: #1c1c1a;
        --color-fg: #e8e7e3;
        --color-muted: #a5a39e;
        --color-border: #2e2d29;
        --color-accent: #f97316;
        --color-accent-hover: #fb923c;
        --color-accent-fg: #0f0f0e;
        --color-ok-bg: #052e1f;
        --color-ok-fg: #a7f3d0;
        --color-ok-border: #065f46;
        --color-err-bg: #2c0a0a;
        --color-err-fg: #fca5a5;
        --color-err-border: #7f1d1d;
      }

      *, *::before, *::after {
        box-sizing: border-box;
      }

      html {
        -webkit-text-size-adjust: 100%;
      }

      body {
        margin: 0;
        font-family: var(--font-sans);
        font-size: 16px;
        line-height: 1.65;
        color: var(--color-fg);
        background: var(--color-bg);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      .container {
        width: 100%;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.25rem;
      }

      main.container {
        flex: 1;
        padding-top: 2rem;
        padding-bottom: 4rem;
      }

      a {
        color: var(--color-accent);
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 2px;
      }

      a:hover {
        color: var(--color-accent-hover);
      }

      h1, h2, h3, h4 {
        line-height: 1.25;
        font-weight: 600;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
      }

      h1 {
        font-size: 2rem;
        margin-top: 1rem;
      }

      h2 {
        font-size: 1.4rem;
        border-bottom: 1px solid var(--color-border);
        padding-bottom: 0.35rem;
      }

      h3 {
        font-size: 1.15rem;
      }

      p {
        margin: 0 0 1rem;
      }

      code {
        font-family: var(--font-mono);
        font-size: 0.92em;
        background: var(--color-bg-subtle);
        padding: 0.1em 0.35em;
        border-radius: 3px;
      }

      pre {
        font-family: var(--font-mono);
        font-size: 0.88rem;
        line-height: 1.55;
        background: var(--color-bg-subtle);
        border: 1px solid var(--color-border);
        border-radius: 6px;
        padding: 0.9rem 1rem;
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        word-break: break-word;
      }

      pre code {
        background: transparent;
        padding: 0;
        border-radius: 0;
      }

      blockquote {
        border-left: 3px solid var(--color-border);
        margin: 1rem 0;
        padding: 0.1rem 1rem;
        color: var(--color-muted);
      }

      hr {
        border: 0;
        border-top: 1px solid var(--color-border);
        margin: 2rem 0;
      }

      table {
        border-collapse: collapse;
        width: 100%;
        margin: 1rem 0;
        font-size: 0.95rem;
      }

      th, td {
        border: 1px solid var(--color-border);
        padding: 0.5rem 0.75rem;
        text-align: left;
      }

      th {
        background: var(--color-bg-subtle);
      }

      ul, ol {
        padding-left: 1.4rem;
      }

      .muted {
        color: var(--color-muted);
        font-size: 0.9rem;
      }

      .site-header {
        border-bottom: 1px solid var(--color-border);
        background: var(--color-bg);
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 1rem;
        padding-bottom: 1rem;
      }

      .wordmark {
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: 1.05rem;
        letter-spacing: 0.02em;
        color: var(--color-fg);
        text-decoration: none;
      }

      .site-header nav a {
        margin-left: 1.25rem;
        color: var(--color-fg);
        text-decoration: none;
        font-size: 0.95rem;
      }

      .site-header nav a:hover {
        color: var(--color-accent);
        text-decoration: underline;
      }

      .color-toggle {
        margin-left: 1.25rem;
        background: transparent;
        border: 1px solid var(--color-border);
        color: var(--color-fg);
        font-size: 1rem;
        line-height: 1;
        width: 1.9rem;
        height: 1.9rem;
        padding: 0;
        border-radius: 999px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-sans);
      }

      .color-toggle:hover {
        color: var(--color-accent);
        border-color: var(--color-accent);
      }

      .color-toggle:focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
      }

      .site-footer {
        border-top: 1px solid var(--color-border);
        background: var(--color-bg-subtle);
        padding: 1.5rem 0;
        font-size: 0.9rem;
      }

      .footer-inner p {
        margin: 0.25rem 0;
      }

      @media (max-width: 480px) {
        h1 { font-size: 1.6rem; }
        h2 { font-size: 1.2rem; }
        .site-header nav a { margin-left: 0.9rem; }
        .color-toggle { margin-left: 0.9rem; }
      }
    </style>

    <script is:inline>
      (function () {
        var icons = {
          light: ['☼', 'Light mode (click for dark)'],
          dark:  ['☾', 'Dark mode (click for auto)'],
          auto:  ['◑', 'Auto / system (click for light)'],
        };
        var cycle = ['auto', 'light', 'dark'];

        function applyScheme(scheme) {
          var root = document.documentElement;
          var btn = document.getElementById('color-toggle');
          if (scheme === 'light' || scheme === 'dark') {
            root.setAttribute('data-color-scheme', scheme);
            root.style.colorScheme = scheme;
          } else {
            root.removeAttribute('data-color-scheme');
            root.style.colorScheme = 'light dark';
          }
          if (btn) {
            var entry = icons[scheme] || icons.auto;
            btn.textContent = entry[0];
            btn.title = entry[1];
            btn.setAttribute('aria-label', entry[1]);
          }
        }

        function currentScheme() {
          try {
            var v = localStorage.getItem('color-scheme');
            if (v === 'light' || v === 'dark') return v;
          } catch (_) {}
          return 'auto';
        }

        function init() {
          var scheme = currentScheme();
          applyScheme(scheme);
          var btn = document.getElementById('color-toggle');
          if (!btn || btn.dataset.bound === '1') return;
          btn.dataset.bound = '1';
          btn.addEventListener('click', function () {
            var next = cycle[(cycle.indexOf(currentScheme()) + 1) % cycle.length];
            try {
              if (next === 'auto') localStorage.removeItem('color-scheme');
              else localStorage.setItem('color-scheme', next);
            } catch (_) {}
            applyScheme(next);
          });
        }

        init();
      })();
    </script>
  </body>
</html>
